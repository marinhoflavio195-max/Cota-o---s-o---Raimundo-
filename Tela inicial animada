<style>
body{
  margin:0;
  background:#8B0000;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
  overflow:hidden;
}

.logo{
  width:250px;
  animation: zoom 2.5s ease-in-out forwards;
}

@keyframes zoom{
  0%{
    transform:scale(0.5);
    opacity:0;
  }
  50%{
    transform:scale(1.1);
    opacity:1;
  }
  100%{
    transform:scale(1);
  }
}
</style>
</head>

