<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>São Raimundo Supermercado</title>

<style>
body{
  margin:0;
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:linear-gradient(135deg,#8B0000,#B22222);
  overflow:hidden;
}

/* Container da logo */
.splash{
  text-align:center;
  animation:fadeIn 1.5s ease-in-out;
}

/* Logo */
.splash img{
  width:220px;
  animation:pulse 2s infinite;
}

/* Nome */
.splash h1{
  color:white;
  font-family:Arial, Helvetica, sans-serif;
  margin-top:20px;
  letter-spacing:2px;
}

/* Animação de entrada */
@keyframes fadeIn{
  from{opacity:0; transform:scale(0.8);}
  to{opacity:1; transform:scale(1);}
}

/* Animação pulsar */
@keyframes pulse{
  0%{transform:scale(1);}
  50%{transform:scale(1.08);}
  100%{transform:scale(1);}
}
</style>
</head>

<body>

<div class="splash">
  <img src="logo.png" alt="São Raimundo">
  <h1>São Raimundo Supermercado</h1>
</div>

<script>
setTimeout(function(){
  window.location.href = "admin.html";
}, 3000);
</script>

</body>
</html>
